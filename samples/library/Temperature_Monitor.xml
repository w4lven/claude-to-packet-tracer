          <TEXT>from options import Options

from time import *
from physical import *
from gpio import *
from environment import Environment
from ioeclient import IoEClient

ENVIRONMENT_NAME = "Ambient Temperature"
METRIC = ""
unit = ""

def setup ():
    IoEClient.setup({
        "type": "Temperature Monitor",
        "states": [{
            "name": "Temperature",
            "type": "number",
            "unit": "&amp;deg;C",
            "imperialUnit": "&amp;deg;F",
            "toImperialConversion": "x*1.8+32",
            "toMetricConversion": "(x-32)/1.8",
            "decimalDigits": 1
        }]
    })

    measurementSystemChangeEvent()


def loop ():
    detect()
    delay(1000)


def measurementSystemChangeEvent ():
    global unit, METRIC
    METRIC = Options.isUsingMetric()
    unit = "C" if METRIC else "F"
    detect()


def detect ():
    value = Environment.get(ENVIRONMENT_NAME)

    setCustomText(30,20,200,20,
        convertTemperature(value) + ' ' + unit)

    IoEClient.reportStates(value)
    setDeviceProperty(getName(), "level", value)


def convertTemperature (value):
    if METRIC:
        return "%.2f"%(value,)
    else:
        return "%.2f"%(value * 1.8 + 32,)


if __name__ == "__main__":
    setup()
    while True:
        loop()
        sleep(0)

