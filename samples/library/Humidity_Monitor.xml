            <TEXT>from options import Options
from time import *
from physical import *
from gpio import *
from environment import Environment
from ioeclient import IoEClient


ENVIRONMENT_NAME = "Humidity"        # var ENVIRONMENT_NAME

level = -1        # var level
unit = ""       # var unit


def setup ():
    global unit
    unit = "%"

    
    IoEClient.setup({
        "type": "Humidity Sensor",
        "states": [{
            "name": "Humidity",
            "type": "number",
            "unit": unit,
            "controllable": False
        }]
    })
    

    detect()



def loop ():

    detect()
    delay(1000)



def detect ():

    value = Environment.get(ENVIRONMENT_NAME)        # var value
    if value &gt;= 0:
        setLevel(Environment.get(ENVIRONMENT_NAME))



def setLevel (newLevel):
    global level
    if level == newLevel:
        return

    level = newLevel
    setCustomText(35, 20, 200, 20, Environment.getValueWithUnit(ENVIRONMENT_NAME))
    IoEClient.reportStates(level)
    setDeviceProperty(getName(), "level", level)



if __name__ == "__main__":
    setup()
    while True:
        loop()
        sleep(0)

