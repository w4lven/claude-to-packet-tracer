            <TEXT>var ENVIRONMENT_NAME = "Humidity";

var level = -1;	
var unit;

function setup() {
	
	unit = "%";
	
	IoEClient.setup({
		type: "Humidity Sensor",
		states: [
		{
			name: "Humidity",
			type: "number",
			unit: unit,
			controllable: false
		}]
	});
	
	detect();
}

function loop() {

	detect();
	delay(1000);
}

function detect()
{

	var value = Environment.get(ENVIRONMENT_NAME);
	if (value &gt;= 0 )
		setLevel( Environment.get(ENVIRONMENT_NAME));
}

function setLevel(newLevel)
{
	if  (level == newLevel)
		return;
		
	level = newLevel;
	setCustomText(35,20,200,20, Environment.getValueWithUnit(ENVIRONMENT_NAME) );
	IoEClient.reportStates(level);
	setDeviceProperty(getName(), "level", level);
}

